@dataclass
class BacktestStats:
    """Backtest performance metrics. Mirrors FloxBacktestStats."""

    total_trades: int
    winning_trades: int
    losing_trades: int
    max_consecutive_wins: int
    max_consecutive_losses: int
    initial_capital: float
    final_capital: float
    total_pnl: float
    total_fees: float
    net_pnl: float
    gross_profit: float
    gross_loss: float
    max_drawdown: float
    max_drawdown_pct: float
    win_rate: float
    profit_factor: float
    avg_win: float
    avg_loss: float
    avg_win_loss_ratio: float
    avg_trade_duration_ns: float
    median_trade_duration_ns: float
    max_trade_duration_ns: float
    sharpe: float
    sortino: float
    calmar: float
    time_weighted_return: float
    return_pct: float
    start_time_ns: int
    end_time_ns: int

    def __repr__(self) -> str:
        return (f"BacktestStats(trades={self.total_trades}, "
                f"win_rate={self.win_rate * 100.0:.1f}%, "
                f"net_pnl={self.net_pnl:.2f}, "
                f"sharpe={self.sharpe:.2f}, "
                f"max_dd={self.max_drawdown_pct * 100.0:.1f}%)")


SLIPPAGE_NONE: int = 0
SLIPPAGE_FIXED_TICKS: int = 1
SLIPPAGE_FIXED_BPS: int = 2
SLIPPAGE_VOLUME_IMPACT: int = 3

QUEUE_NONE: int = 0
QUEUE_TOB: int = 1
QUEUE_FULL: int = 2

OUTAGE_CANCEL_ALL: int = 0
OUTAGE_HOLD: int = 1
OUTAGE_EXPIRE_GTC_AFTER: int = 2


class VenueAvailability:
    """Venue downtime model. Attach to `SimulatedExecutor` via
    `set_venue_availability(va)` to make submit / cancel / replace
    buffer during outages and market-data callbacks be silently
    dropped (feed gap). Buffered requests flush at the recovery edge
    in FIFO order."""

    _h: cobj

    def __init__(self):
        self._h = flox_venue_availability_create()

    def close(self):
        if self._h != cobj():
            flox_venue_availability_destroy(self._h)
            self._h = cobj()

    def schedule_outage(self, start_ns: int, duration_ns: int,
                        on_open_orders: int = 0, gtc_ttl_ns: int = 0):
        flox_venue_availability_schedule_outage(
            self._h, i64(start_ns), i64(duration_ns), u8(on_open_orders),
            i64(gtc_ttl_ns))

    def auto_random_outages(self, per_day: float, mean_duration_ns: int,
                            on_open_orders: int = 0, seed: int = 0xC0FFEE):
        flox_venue_availability_auto_random_outages(
            self._h, f64(per_day), i64(mean_duration_ns), u8(on_open_orders),
            u64(seed))

    def is_up(self, now_ns: int) -> bool:
        return int(flox_venue_availability_is_up(self._h, i64(now_ns))) != 0

    def schedule_outage_ex(self, start_ns: int, duration_ns: int,
                           outage_type: int = 0, on_open_orders: int = 0,
                           gtc_ttl_ns: int = 0,
                           degradation_latency_multiplier: float = 1.0,
                           wrong_side_recovery_bps: float = 0.0):
        """outage_type: 0=Total, 1=SubmitOnlyDown, 2=CancelOnlyDown,
        3=SlowDegradation, 4=StaleBook, 5=WrongSideRecovery."""
        flox_venue_availability_schedule_outage_ex(
            self._h, i64(start_ns), i64(duration_ns), u8(outage_type),
            u8(on_open_orders), i64(gtc_ttl_ns),
            f64(degradation_latency_multiplier), f64(wrong_side_recovery_bps))

    def submits_allowed(self, now_ns: int) -> bool:
        return int(flox_venue_availability_submits_allowed(self._h, i64(now_ns))) != 0

    def cancels_allowed(self, now_ns: int) -> bool:
        return int(flox_venue_availability_cancels_allowed(self._h, i64(now_ns))) != 0

    def book_updates_allowed(self, now_ns: int) -> bool:
        return int(flox_venue_availability_book_updates_allowed(
            self._h, i64(now_ns))) != 0

    def trades_allowed(self, now_ns: int) -> bool:
        return int(flox_venue_availability_trades_allowed(self._h, i64(now_ns))) != 0

    def latency_multiplier(self, now_ns: int) -> float:
        return float(flox_venue_availability_latency_multiplier(self._h, i64(now_ns)))

    def consume_wrong_side_recovery_bps(self) -> float:
        return float(flox_venue_availability_consume_wrong_side_recovery_bps(self._h))

    def handle(self) -> cobj:
        return self._h


class LatencyDistribution:
    """Ack-latency distribution. Build via class methods, attach via
    `SimulatedExecutor.set_*_ack_latency_distribution(d)`."""

    _h: cobj

    def __init__(self):
        self._h = flox_latency_distribution_create()

    def close(self):
        if self._h != cobj():
            flox_latency_distribution_destroy(self._h)
            self._h = cobj()

    @staticmethod
    def constant(ns: int):
        d = LatencyDistribution()
        flox_latency_distribution_set_constant(d._h, i64(ns))
        return d

    @staticmethod
    def uniform(lo_ns: int, hi_ns: int):
        d = LatencyDistribution()
        flox_latency_distribution_set_uniform(d._h, i64(lo_ns), i64(hi_ns))
        return d

    @staticmethod
    def lognormal(median_ns: int, sigma: float):
        d = LatencyDistribution()
        flox_latency_distribution_set_lognormal(d._h, i64(median_ns), f64(sigma))
        return d

    @staticmethod
    def empirical(samples_ns: List[int]):
        d = LatencyDistribution()
        buf = [i64(s) for s in samples_ns]
        flox_latency_distribution_set_empirical(
            d._h, cobj() if len(buf) == 0 else cobj(buf.arr.ptr), u32(len(buf)))
        return d

    def set_burst_correlation(self, rho: float):
        flox_latency_distribution_set_burst_correlation(self._h, f64(rho))

    def median_ns(self) -> int:
        return int(flox_latency_distribution_median_ns(self._h))

    def handle(self) -> cobj:
        return self._h


class SimulatedExecutor:
    """Thin wrapper around the C API simulated executor."""

    _handle: cobj

    def __init__(self):
        self._handle = flox_simulated_executor_create()

    def close(self):
        if self._handle != cobj():
            flox_simulated_executor_destroy(self._handle)
            self._handle = cobj()

    def submit_order(self, id: int, side: str, price: float, quantity: float,
                     order_type: str = "market", symbol: int = 1):
        side_u = u8(0 if side == "buy" else 1)
        t = 1
        if order_type == "limit":
            t = 0
        elif order_type == "stop_market":
            t = 2
        elif order_type == "stop_limit":
            t = 3
        elif order_type == "take_profit_market":
            t = 4
        elif order_type == "take_profit_limit":
            t = 5
        elif order_type == "trailing_stop":
            t = 6
        flox_simulated_executor_submit_order(self._handle, u64(id), side_u, price, quantity,
                                   u8(t), u32(symbol))

    def submit_order_ex(self, id: int, side: str, price: float, quantity: float,
                         order_type: str = "market", symbol: int = 1,
                         tif: str = "gtc", reduce_only: bool = False,
                         expires_at_ns: int = 0):
        """Extended submit with TIF / reduce_only / GTD deadline.
        tif: gtc | ioc | fok | gtd | post_only."""
        side_u = u8(0 if side == "buy" else 1)
        t = 1
        if order_type == "limit":
            t = 0
        elif order_type == "stop_market":
            t = 2
        elif order_type == "stop_limit":
            t = 3
        elif order_type == "take_profit_market":
            t = 4
        elif order_type == "take_profit_limit":
            t = 5
        elif order_type == "trailing_stop":
            t = 6
        tif_u = 0
        if tif == "ioc":
            tif_u = 1
        elif tif == "fok":
            tif_u = 2
        elif tif == "gtd":
            tif_u = 3
        elif tif == "post_only":
            tif_u = 4
        flox_simulated_executor_submit_order_ex(
            self._handle, u64(id), side_u, price, quantity, u8(t), u32(symbol),
            u8(tif_u), u8(1 if reduce_only else 0), i64(expires_at_ns))

    def cancel_order(self, order_id: int):
        flox_simulated_executor_cancel_order(self._handle, u64(order_id))

    def cancel_all(self, symbol: int):
        flox_simulated_executor_cancel_all(self._handle, u32(symbol))

    def on_bar(self, symbol: int, close_price: float):
        flox_simulated_executor_on_bar(self._handle, u32(symbol), close_price)

    def on_trade(self, symbol: int, price: float, is_buy: bool):
        flox_simulated_executor_on_trade(self._handle, u32(symbol), price,
                               u8(1 if is_buy else 0))

    def on_trade_qty(self, symbol: int, price: float, quantity: float, is_buy: bool):
        flox_simulated_executor_on_trade_qty(self._handle, u32(symbol), price, quantity,
                                   u8(1 if is_buy else 0))

    def on_best_levels(self, symbol: int, bid_price: float, bid_qty: float,
                       ask_price: float, ask_qty: float):
        flox_simulated_executor_on_best_levels(self._handle, u32(symbol), bid_price, bid_qty,
                                     ask_price, ask_qty)

    def advance_clock(self, timestamp_ns: int):
        flox_simulated_executor_advance_clock(self._handle, i64(timestamp_ns))

    def set_default_slippage(self, model: int, ticks: int = 0,
                             tick_size: float = 0.0, bps: float = 0.0,
                             impact_coeff: float = 0.0):
        flox_simulated_executor_set_default_slippage(self._handle, i32(model), i32(ticks),
                                           tick_size, bps, impact_coeff)

    def set_symbol_slippage(self, symbol: int, model: int, ticks: int = 0,
                            tick_size: float = 0.0, bps: float = 0.0,
                            impact_coeff: float = 0.0):
        flox_simulated_executor_set_symbol_slippage(self._handle, u32(symbol), i32(model),
                                          i32(ticks), tick_size, bps, impact_coeff)

    def set_queue_model(self, model: int, depth: int = 1):
        flox_simulated_executor_set_queue_model(self._handle, i32(model), u32(depth))

    def submit_bracket(self, bracket_id: int, symbol: int,
                       entry_side: str, entry_type: str, entry_price: float,
                       quantity: float,
                       tp_side: str, tp_type: str, tp_price: float,
                       stop_side: str, stop_type: str, stop_trigger_price: float):
        """Submit a native bracket (entry + take-profit + stop). The
        simulator manages the state machine: first child to fill
        cancels the other."""
        def side_u(s: str) -> int:
            return 0 if s == "buy" else 1
        def type_u(t: str) -> int:
            if t == "market": return 1
            if t == "stop_market": return 2
            if t == "stop_limit": return 3
            return 0  # limit
        flox_simulated_executor_submit_bracket(
            self._handle, u64(bracket_id), u32(symbol),
            u8(side_u(entry_side)), u8(type_u(entry_type)),
            entry_price, quantity,
            u8(side_u(tp_side)), u8(type_u(tp_type)), tp_price,
            u8(side_u(stop_side)), u8(type_u(stop_type)), stop_trigger_price)

    def cancel_bracket(self, bracket_id: int):
        flox_simulated_executor_cancel_bracket(self._handle, u64(bracket_id))

    def bracket_state(self, bracket_id: int) -> str:
        s = int(flox_simulated_executor_bracket_state(self._handle, u64(bracket_id)))
        names = ["pending_entry", "entry_filled", "tp_filled", "stop_filled", "canceled"]
        return names[s] if 0 <= s < len(names) else "pending_entry"

    def set_bracket_child_arm_mode(self, mode: str):
        """Mode: 'on_full_fill' (default) | 'on_partial_fill'."""
        v = 1 if mode == "on_partial_fill" else 0
        flox_simulated_executor_set_bracket_child_arm_mode(self._handle, u8(v))

    def set_queue_fifo_top_n(self, top_n: int):
        flox_simulated_executor_set_queue_fifo_top_n(self._handle, u32(top_n))

    def set_top_priority_share(self, share: float):
        flox_simulated_executor_set_top_priority_share(self._handle, f64(share))

    def set_lmm_orders(self, ids: List[int]):
        n = len(ids)
        if n == 0:
            flox_simulated_executor_set_lmm_orders(self._handle, cobj(), u32(0))
            return
        buf = [u64(i) for i in ids]
        flox_simulated_executor_set_lmm_orders(
            self._handle, cobj(buf.arr.ptr), u32(n))

    def set_lmm_bonus_multiplier(self, multiplier: float):
        flox_simulated_executor_set_lmm_bonus_multiplier(self._handle, f64(multiplier))

    def set_order_priority_multiplier(self, order_id: int, multiplier: float):
        flox_simulated_executor_set_order_priority_multiplier(
            self._handle, u64(order_id), f64(multiplier))

    def set_venue_availability(self, va: VenueAvailability):
        flox_simulated_executor_set_venue_availability(self._handle, va.handle())

    def submit_iceberg(self, id: int, side: str, price: float,
                       total_quantity: float, visible_quantity: float,
                       symbol: int = 1):
        """Submit a native iceberg. Only `visible_quantity` is exposed;
        the hidden remainder auto-refreshes as the visible tranche fills."""
        side_u = u8(0 if side == "buy" else 1)
        flox_simulated_executor_submit_iceberg(
            self._handle, u64(id), side_u, price, total_quantity,
            visible_quantity, u32(symbol))

    def set_iceberg_refresh_latency(self, latency_ns: int):
        flox_simulated_executor_set_iceberg_refresh_latency(self._handle, i64(latency_ns))

    def iceberg_hidden_remaining_raw(self, id: int) -> int:
        return int(flox_simulated_executor_iceberg_hidden_remaining_raw(
            self._handle, u64(id)))

    def set_iceberg_size_randomisation_pct(self, pct: float):
        """Per-refresh visible-slice size jitter (0.0 deterministic; 0.10 = ±10%)."""
        flox_simulated_executor_set_iceberg_size_randomisation_pct(
            self._handle, f64(pct))

    def set_iceberg_priority_mode(self, mode: str):
        """Queue priority on refresh: 'back' (default) | 'retain'."""
        code = u8(1 if mode == "retain" else 0)
        flox_simulated_executor_set_iceberg_priority_mode(self._handle, code)

    def set_iceberg_jitter_seed(self, seed: int):
        flox_simulated_executor_set_iceberg_jitter_seed(self._handle, u64(seed))

    def set_submit_ack_latency(self, latency_ns: int, jitter_ns: int = 0):
        flox_simulated_executor_set_submit_ack_latency(
            self._handle, i64(latency_ns), i64(jitter_ns))

    def set_cancel_ack_latency(self, latency_ns: int, jitter_ns: int = 0):
        flox_simulated_executor_set_cancel_ack_latency(
            self._handle, i64(latency_ns), i64(jitter_ns))

    def set_replace_ack_latency(self, latency_ns: int, jitter_ns: int = 0):
        flox_simulated_executor_set_replace_ack_latency(
            self._handle, i64(latency_ns), i64(jitter_ns))

    def apply_latency_profile(self, name: str):
        # Codon strings are utf-8; pass as cobj pointer to bytes.
        # The C side reads name as const char*.
        from internal.gc import sys_alloc
        n = len(name)
        buf = Ptr[byte](sys_alloc(n + 1))
        for i in range(n):
            buf[i] = byte(ord(name[i]))
        buf[n] = byte(0)
        flox_simulated_executor_apply_latency_profile(self._handle, cobj(buf))

    def set_submit_ack_latency_distribution(self, dist: LatencyDistribution):
        flox_simulated_executor_set_submit_ack_latency_distribution(
            self._handle, dist.handle())

    def set_cancel_ack_latency_distribution(self, dist: LatencyDistribution):
        flox_simulated_executor_set_cancel_ack_latency_distribution(
            self._handle, dist.handle())

    def set_replace_ack_latency_distribution(self, dist: LatencyDistribution):
        flox_simulated_executor_set_replace_ack_latency_distribution(
            self._handle, dist.handle())

    def set_rate_limit_policy(self, policy):
        """Attach a rate-limit policy. Policy is a flox.rate_limit.RateLimitPolicy."""
        flox_simulated_executor_set_rate_limit_policy(self._handle, policy.handle())

    def clear_rate_limit_policy(self):
        flox_simulated_executor_clear_rate_limit_policy(self._handle)

    def set_stp_mode(self, mode: str):
        """Self-trade prevention mode. mode in {none, cancel_newest,
        cancel_oldest, cancel_both, decrement}."""
        m = 0
        if mode == "cancel_newest": m = 1
        elif mode == "cancel_oldest": m = 2
        elif mode == "cancel_both": m = 3
        elif mode == "decrement": m = 4
        flox_simulated_executor_set_stp_mode(self._handle, u8(m))

    def set_stp_group_membership(self, account_id: int, group_id: int):
        """Opt an STP account into a group. group_id=0 removes mapping."""
        flox_simulated_executor_set_stp_group_membership(
            self._handle, u64(account_id), u64(group_id))

    def stp_group_for(self, account_id: int) -> int:
        return int(flox_simulated_executor_stp_group_for(self._handle, u64(account_id)))

    def set_fok_mode(self, mode):
        """FOK fill semantic: 'any_price' (default) or 'single_price'."""
        code = u8(0)
        if isinstance(mode, str):
            if mode.lower() == "single_price":
                code = u8(1)
        else:
            code = u8(int(mode))
        flox_simulated_executor_set_fok_mode(self._handle, code)

    def fok_mode(self) -> str:
        code = int(flox_simulated_executor_fok_mode(self._handle))
        return "single_price" if code == 1 else "any_price"

    def handle(self) -> cobj:
        return self._handle

    def fill_count(self) -> int:
        return int(flox_simulated_executor_fill_count(self._handle))


class LiquidationEngine:
    """Liquidation + insurance fund + ADL engine. Open positions via
    `open_position` then call `on_mark(symbol, mark)` on each tick;
    the engine fires liquidations + ADL where required and updates
    cumulative stats."""

    _h: cobj

    def __init__(self):
        self._h = flox_liquidation_engine_create()

    def close(self):
        if self._h != cobj():
            flox_liquidation_engine_destroy(self._h)
            self._h = cobj()

    def add_tier(self, min_notional: float, mm_fraction: float):
        flox_liquidation_engine_add_tier(self._h, f64(min_notional), f64(mm_fraction))

    def set_insurance_fund_capital(self, capital: float):
        flox_liquidation_engine_set_insurance_fund_capital(self._h, f64(capital))

    def insurance_fund_balance(self) -> float:
        return float(flox_liquidation_engine_insurance_fund_balance(self._h))

    def set_adl_enabled(self, enabled: bool):
        flox_liquidation_engine_set_adl_enabled(self._h, u8(1 if enabled else 0))

    def set_adl_ranking(self, ranking):
        # Accepts an int code (0..3) or a string name.
        code = u8(0)
        if isinstance(ranking, str):
            name = ranking.lower()
            if name == "binance":
                code = u8(1)
            elif name == "bybit":
                code = u8(2)
            elif name == "position_size":
                code = u8(3)
        else:
            code = u8(int(ranking))
        flox_liquidation_engine_set_adl_ranking(self._h, code)

    def adl_ranking(self) -> int:
        return int(flox_liquidation_engine_adl_ranking(self._h))

    def set_liquidation_slippage_bps(self, bps: float):
        flox_liquidation_engine_set_liquidation_slippage_bps(self._h, f64(bps))

    def open_position(self, account_id: int, symbol: int, quantity: float,
                      entry_price: float, equity: float):
        flox_liquidation_engine_open_position(
            self._h, u64(account_id), u32(symbol),
            f64(quantity), f64(entry_price), f64(equity))

    def close_position(self, account_id: int, symbol: int):
        flox_liquidation_engine_close_position(self._h, u64(account_id), u32(symbol))

    def on_mark(self, symbol: int, mark_price: float) -> int:
        return int(flox_liquidation_engine_on_mark(self._h, u32(symbol), f64(mark_price)))

    def liquidations_count(self) -> int:
        return int(flox_liquidation_engine_liquidations_count(self._h))

    def insurance_payments_count(self) -> int:
        return int(flox_liquidation_engine_insurance_payments_count(self._h))

    def adl_closeouts_count(self) -> int:
        return int(flox_liquidation_engine_adl_closeouts_count(self._h))

    def load_profile(self, profile: int):
        """Profile: 0=binance_um_futures, 1=bybit_linear, 2=okx_swap."""
        flox_liquidation_engine_load_profile(self._h, u8(profile))

    def set_executor(self, executor: SimulatedExecutor):
        """Attach a SimulatedExecutor so liquidation orders route
        through it as market orders. Pass None to detach (caller
        passes a default-constructed executor with closed handle
        for explicit detach; passing this method is the wiring,
        detach via setExecutor on a fresh engine)."""
        flox_liquidation_engine_set_executor(self._h, executor._handle)

    def ticks_to_first_adl(self) -> int:
        return int(flox_liquidation_engine_ticks_to_first_adl(self._h))

    def reset_stats(self):
        flox_liquidation_engine_reset_stats(self._h)

    def set_mark_impact_model(self, model, weight: float = 0.3):
        # model: int code (0..2) or a string name (none, book_anchored, book_only).
        code = u8(0)
        if isinstance(model, str):
            name = model.lower()
            if name == "book_anchored":
                code = u8(1)
            elif name == "book_only":
                code = u8(2)
        else:
            code = u8(int(model))
        flox_liquidation_engine_set_mark_impact_model(self._h, code, f64(weight))

    def mark_impact_model(self) -> int:
        return int(flox_liquidation_engine_mark_impact_model(self._h))

    def mark_impact_weight(self) -> float:
        return float(flox_liquidation_engine_mark_impact_weight(self._h))

    def set_max_cascade_depth(self, depth: int):
        flox_liquidation_engine_set_max_cascade_depth(self._h, u32(depth))

    def max_cascade_depth(self) -> int:
        return int(flox_liquidation_engine_max_cascade_depth(self._h))

    def attach_account(self, account):
        """Attach an Account so its positions participate in cross-margin
        MM checks. Multiple accounts may be attached. Codon does not
        accept the forward type annotation here because Account is
        defined below; duck-typed via `_h`."""
        flox_liquidation_engine_attach_account(self._h, account._h)

    def detach_account(self, account_id: int):
        flox_liquidation_engine_detach_account(self._h, u64(account_id))


class Account:
    """Cross-margin shared state owned by an account. Attach to a
    LiquidationEngine and/or FeeSchedule to share equity, positions,
    and 30d rolling notional across symbols."""

    _h: cobj

    def __init__(self, account_id: int = 0, equity: float = 0.0):
        self._h = flox_account_create(u64(account_id), f64(equity))

    def close(self):
        if self._h != cobj():
            flox_account_destroy(self._h)
            self._h = cobj()

    def account_id(self) -> int:
        return int(flox_account_id(self._h))

    def equity(self) -> float:
        return float(flox_account_equity(self._h))

    def set_equity(self, equity: float):
        flox_account_set_equity(self._h, f64(equity))

    def add_equity(self, delta: float):
        flox_account_add_equity(self._h, f64(delta))

    def margin_mode(self) -> int:
        return int(flox_account_margin_mode(self._h))

    def set_margin_mode(self, mode):
        # mode: int code (0=cross, 1=isolated) or a string name.
        code = u8(0)
        if isinstance(mode, str):
            name = mode.lower()
            if name == "isolated":
                code = u8(1)
        else:
            code = u8(int(mode))
        flox_account_set_margin_mode(self._h, code)

    def open_position(self, symbol: int, quantity: float, entry_price: float):
        flox_account_open_position(self._h, u32(symbol), f64(quantity), f64(entry_price))

    def close_position(self, symbol: int):
        flox_account_close_position(self._h, u32(symbol))

    def position_count(self) -> int:
        return int(flox_account_position_count(self._h))

    def set_mark(self, symbol: int, price: float):
        flox_account_set_mark(self._h, u32(symbol), f64(price))

    def total_notional(self) -> float:
        return float(flox_account_total_notional(self._h))

    def total_unrealised_pnl(self) -> float:
        return float(flox_account_total_unrealised_pnl(self._h))

    def record_fill(self, ts_ns: int, notional: float):
        flox_account_record_fill(self._h, i64(ts_ns), f64(notional))

    def rolling_notional_30d(self) -> float:
        return float(flox_account_rolling_notional_30d(self._h))

    def reset_rolling(self):
        flox_account_reset_rolling(self._h)


class BacktestResult:
    """Aggregates simulated fills into trades, stats, and an equity curve."""

    _handle: cobj

    def __init__(self, initial_capital: float = 100000.0, fee_rate: float = 0.0001,
                 use_percentage_fee: bool = True, fixed_fee_per_trade: float = 0.0,
                 risk_free_rate: float = 0.0, annualization_factor: float = 252.0):
        self._handle = flox_backtest_result_create(
            initial_capital, fee_rate,
            u8(1 if use_percentage_fee else 0), fixed_fee_per_trade,
            risk_free_rate, annualization_factor)

    def close(self):
        if self._handle != cobj():
            flox_backtest_result_destroy(self._handle)
            self._handle = cobj()

    def record_fill(self, order_id: int, symbol: int, side: str, price: float,
                    quantity: float, timestamp_ns: int):
        side_u = u8(0 if side == "buy" else 1)
        flox_backtest_result_record_fill(self._handle, u64(order_id), u32(symbol),
                                         side_u, price, quantity, i64(timestamp_ns))

    def ingest_executor(self, executor: SimulatedExecutor):
        flox_backtest_result_ingest_executor(self._handle, executor.handle())

    def equity_curve_size(self) -> int:
        return int(flox_backtest_result_equity_curve(self._handle, cobj(), u32(0)))

    def write_equity_curve_csv(self, path: str) -> bool:
        return int(flox_backtest_result_write_equity_curve_csv(self._handle, path)) == 1

    def stats(self) -> BacktestStats:
        """Return backtest performance metrics.

        All FloxBacktestStats fields are 8 bytes (u64/f64/i64), so a
        List[i64] buffer has the correct memory layout.  Float fields
        are read back via a Ptr[f64] alias over the same buffer.
        """
        buf = [i64(0)] * 29
        flox_backtest_result_stats(self._handle, buf.arr.ptr)
        fp = Ptr[f64](buf.arr.ptr)
        return BacktestStats(
            total_trades=int(buf[0]),
            winning_trades=int(buf[1]),
            losing_trades=int(buf[2]),
            max_consecutive_wins=int(buf[3]),
            max_consecutive_losses=int(buf[4]),
            initial_capital=fp[5],
            final_capital=fp[6],
            total_pnl=fp[7],
            total_fees=fp[8],
            net_pnl=fp[9],
            gross_profit=fp[10],
            gross_loss=fp[11],
            max_drawdown=fp[12],
            max_drawdown_pct=fp[13],
            win_rate=fp[14],
            profit_factor=fp[15],
            avg_win=fp[16],
            avg_loss=fp[17],
            avg_win_loss_ratio=fp[18],
            avg_trade_duration_ns=fp[19],
            median_trade_duration_ns=fp[20],
            max_trade_duration_ns=fp[21],
            sharpe=fp[22],
            sortino=fp[23],
            calmar=fp[24],
            time_weighted_return=fp[25],
            return_pct=fp[26],
            start_time_ns=int(buf[27]),
            end_time_ns=int(buf[28])
        )
