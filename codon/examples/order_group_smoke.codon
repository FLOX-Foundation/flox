# Codon smoke for the multi-leg order group state machine.
# Drives the same scenarios as the NAPI / QuickJS tests.

from flox.order_group import (
    OrderGroup, OrderGroupAction,
    BEST_EFFORT, ALL_OR_NOTHING, ONE_SIDED,
    GROUP_PENDING, GROUP_SUBMITTED, GROUP_PARTIAL, GROUP_FILLED,
    GROUP_REVERTING,
    LEG_FILLED, LEG_FAILED,
)


def check(label: str, ok: bool):
    if not ok:
        print("FAIL: " + label)
        raise ValueError("smoke fail: " + label)
    print("ok: " + label)


def run():
    # --- BestEffort: nothing reverts.
    g = OrderGroup(parent_signal_id=1, policy=BEST_EFFORT)
    a = g.add_market_leg(1, 0, 0.1)
    b = g.add_market_leg(2, 1, 2.0)
    check("legCount = 2", g.leg_count() == 2)
    check("initial state Pending", g.state() == GROUP_PENDING)
    g.record_submit(a, 100)
    g.record_submit(b, 101)
    check("post-submit Submitted", g.state() == GROUP_SUBMITTED)
    g.record_fill(a, 0.1)
    g.record_failure(b)
    check("partial fill + failure → PartiallyFilled", g.state() == GROUP_PARTIAL)
    acts = g.recommended_actions()
    check("BestEffort recommends nothing", len(acts) == 0)

    # --- OneSided: first fill cancels remaining.
    g2 = OrderGroup(parent_signal_id=2, policy=ONE_SIDED)
    g2.add_limit_leg(1, 0, 50000.0, 0.1)
    g2.add_limit_leg(2, 1, 3000.0, 1.5)
    g2.record_submit(0, 200)
    g2.record_submit(1, 201)
    g2.record_fill(0, 0.1)
    acts2 = g2.recommended_actions()
    check("OneSided: 1 cancel for unfilled leg", len(acts2) == 1)
    check("OneSided: cancel kind", acts2[0].kind == "cancel")
    check("OneSided: cancel leg index 1", acts2[0].leg_index == 1)
    check("OneSided: cancel order id 201", acts2[0].order_id == 201)

    # --- AllOrNothing: failure → revert filled legs.
    g3 = OrderGroup(parent_signal_id=3, policy=ALL_OR_NOTHING)
    g3.add_market_leg(1, 0, 0.1)
    g3.add_market_leg(2, 1, 2.0)
    g3.record_submit(0, 300)
    g3.record_submit(1, 301)
    g3.record_fill(0, 0.1)
    g3.record_failure(1)
    check("AllOrNothing: state Reverting", g3.state() == GROUP_REVERTING)
    acts3 = g3.recommended_actions()
    check("AllOrNothing: 1 revert action", len(acts3) == 1)
    check("AllOrNothing: revert kind", acts3[0].kind == "revert")
    check("AllOrNothing: revert opposite side", acts3[0].side == 1)
    check("AllOrNothing: revert symbol matches", acts3[0].symbol == 1)
    check("AllOrNothing: revert qty matches fill",
          abs(acts3[0].qty - 0.1) < 1e-6)

    # --- auto_dispatch: fires through a fake strategy and is idempotent.
    @dataclass
    class FakeStrat:
        cancels: List[int]
        buys: List[Tuple[int, float]]
        sells: List[Tuple[int, float]]

        def emit_cancel(self, order_id: int):
            self.cancels.append(order_id)

        def emit_market_buy(self, symbol: int, qty: float):
            self.buys.append((symbol, qty))

        def emit_market_sell(self, symbol: int, qty: float):
            self.sells.append((symbol, qty))

    s = FakeStrat(cancels=list[int](), buys=list[Tuple[int, float]](),
                   sells=list[Tuple[int, float]]())
    g4 = OrderGroup(parent_signal_id=4, policy=ALL_OR_NOTHING)
    g4.add_market_leg(1, 0, 0.1)
    g4.add_market_leg(2, 1, 2.0)
    g4.record_submit(0, 400); g4.record_submit(1, 401)
    g4.record_fill(0, 0.1); g4.record_failure(1)
    fired = g4.auto_dispatch(s)
    check("auto_dispatch fired 1", fired == 1)
    check("auto_dispatch emitted a sell", len(s.sells) == 1)
    check("auto_dispatch sell symbol = 1", s.sells[0][0] == 1)
    check("auto_dispatch idempotent", g4.auto_dispatch(s) == 0)

    # --- Group-level risk gate: basket over concentration cap denied.
    g5 = OrderGroup(parent_signal_id=5, policy=BEST_EFFORT)
    g5.add_market_leg(1, 0, 0.1)
    g5.add_market_leg(2, 1, 2.0)
    g5.set_risk_limits(max_concentration_pct=0.05)
    denied, rule, _ = g5.precheck_submission(equity=100_000.0,
                                              market_ref_prices=[50_000.0, 3_000.0])
    check("risk gate denies oversized basket", denied)
    check("risk gate names rule", rule == "maxConcentrationPct")
    g6 = OrderGroup(parent_signal_id=6, policy=BEST_EFFORT)
    g6.add_market_leg(1, 0, 0.001)
    g6.set_risk_limits(max_concentration_pct=0.05)
    d6, _r6, _d6 = g6.precheck_submission(equity=100_000.0, market_ref_prices=[50_000.0])
    check("risk gate allows small basket", not d6)

    # --- OneSided pair-latency budget.
    g7 = OrderGroup(parent_signal_id=7, policy=ONE_SIDED)
    g7.add_limit_leg(1, 0, 50000.0, 0.1)
    g7.add_limit_leg(2, 1, 3000.0, 1.5)
    check("budget unset → wait",
          g7.pair_latency_decision(0, 0, False) == "wait")

    g7.set_pair_latency_budget_ns(50_000_000)
    submit = 1_000_000_000
    check("ack within budget → submit_follower",
          g7.pair_latency_decision(submit, submit + 30_000_000, True) == "submit_follower")
    check("ack over budget → cancel_leader",
          g7.pair_latency_decision(submit, submit + 60_000_000, True) == "cancel_leader")
    check("no ack, still inside budget → wait",
          g7.pair_latency_decision(submit, submit + 10_000_000, False) == "wait")
    check("no ack, past budget → cancel_leader (timeout)",
          g7.pair_latency_decision(submit, submit + 80_000_000, False) == "cancel_leader")

    print("codon order_group smoke ok")


run()
