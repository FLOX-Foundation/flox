"""${name} — hybrid strategy.

Maintains a fast tick-level filter (``on_trade``) plus a slower
bar-level confirmation (``on_bar``). Useful when bar TA gives
direction and tick state controls entry timing.
"""
from __future__ import annotations

import flox_py as flox


class ${name}(flox.Strategy):
    def __init__(self, symbols, *, bar_period: int = 20,
                 tick_period: int = 5):
        super().__init__(symbols)
        self.bar_ema = flox.EMA(bar_period)
        self.tick_ema = flox.EMA(tick_period)
        self.bar_trend = 0  # +1 up, -1 down, 0 unknown

    def on_bar(self, ctx, bar):
        v = self.bar_ema.update(bar.close)
        if v is None:
            return
        self.bar_trend = 1 if bar.close > v else -1

    def on_trade(self, ctx, trade):
        f = self.tick_ema.update(trade.price)
        if f is None or self.bar_trend == 0:
            return
        if self.bar_trend > 0 and trade.price > f and ctx.is_flat():
            self.market_buy(0.01)
        elif self.bar_trend < 0 and ctx.is_long():
            self.market_sell(0.01)
