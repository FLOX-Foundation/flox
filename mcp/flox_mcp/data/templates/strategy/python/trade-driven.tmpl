"""${name} — trade-driven strategy.

Reacts on every print (``on_trade``); ignores bars. Use this kind
when your signal cares about microstructure or sub-bar latency.
"""
from __future__ import annotations

import flox_py as flox


class ${name}(flox.Strategy):
    def __init__(self, symbols, *, period: int = 20):
        super().__init__(symbols)
        self.ema = flox.EMA(period)
        self.last_signal = 0

    def on_trade(self, ctx, trade):
        v = self.ema.update(trade.price)
        if v is None:
            return
        if trade.price > v and self.last_signal != 1 and ctx.is_flat():
            self.market_buy(0.01)
            self.last_signal = 1
        elif trade.price < v and self.last_signal != -1 and ctx.is_long():
            self.market_sell(0.01)
            self.last_signal = -1
